# ── Python ────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── 가상환경 ───────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── 환경변수 / 시크릿 ──────────────────────────────────
.env
.env.local
.env.*.local
# .env.example 은 예시 파일이므로 추적 유지

# ── SAP 데이터 파일 (원본 민감 데이터) ────────────────
data/
rawdata/
input/
*.csv
# 단, 테스트용 샘플은 예외
!tests/fixtures/*.csv

# ── 결과물 Excel (자동 생성) ───────────────────────────
*_정리완료_*.xlsx
*_매칭결과_*.xlsx
GRIR_매칭결과_*.xlsx

# ── IDE / 에디터 ───────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── pytest / 테스트 캐시 ───────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── 로그 ──────────────────────────────────────────────
*.log
logs/

# ── 임시 파일 ─────────────────────────────────────────
tmp/
temp/
*.tmp
*.bak
